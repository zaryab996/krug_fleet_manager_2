# ============================================================
# Krug Fleet Manager – Umgebungsvariablen
# Diese Datei als .env.local kopieren und die Werte eintragen
# ============================================================

# ─── Supabase (persistente Datenspeicherung) ─────────────────
# Pflicht für geräteübergreifende Datenpersistenz
#
# Werte finden: Supabase Dashboard → Project Settings → API
#
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ─── EmailJS (optionaler E-Mail-Versand) ─────────────────────
# Kann alternativ über Admin → E-Mail konfiguriert werden

# Willkommens-E-Mails (neuer Benutzer)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Fahrzeug-E-Mails (VIN-basierter Absender)
VITE_EMAILJS_VEHICLE_TEMPLATE_ID=template_xxxxxxx

# EmailJS Public Key (Account → General)
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
